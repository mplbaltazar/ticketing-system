<!DOCTYPE html>
<html>
<head>
    <title>Admin Dashboard</title>
    <link rel="stylesheet" href="/styles/style.css">
</head>
<%- include('header') %>
<body>
    <div class="container">
        <div class="header">
            <h2>Technician Management</h2>
            <a href="<%= backUrl %>" class="btn">Back</a>
            <a href="#" onclick="confirmLogout()" class="btn logout-btn">Logout</a>
        </div>

<table>
    <thead>
        <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Position</th>
            <th>Open Tickets</th>
            <th>Total Tickets</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        <% technicians.forEach(tech => { %>
            <tr>
                <td><%= tech.full_name %></td>
                <td><%= tech.email %></td>
                <td><%= tech.position %></td>
                <td><%= tech.open_tickets || 0 %></td>
                <td><%= tech.total_tickets || 0 %></td>
                <td>
                    <a href="/admin/technician/<%= tech.user_id %>/tickets">View Tickets</a>
                </td>
            </tr>
        <% }) %>
    </tbody>
</table>
</body>

<script>
    function confirmLogout() {
        showConfirm("Are you sure you want to logout?", function () {
            window.location.href = "/logout";
        });
    }
</script>