<!DOCTYPE html>
<html>
<head>
    <title>Technician Dashboard</title>
    <link rel="stylesheet" href="/styles/style.css">
</head>
<%- include('header') %>
<body>
<div class="container">
    <div class="header">
        <h2>Technician Dashboard</h2>
        <div class="header-actions">
            <a href="/tickets/create" class="btn create-btn">+ Create Ticket</a>
            <a href="#" onclick="confirmLogout()" class="btn logout-btn">Logout</a>
        </div>
    </div>

    <div class="content">
        <h3>Welcome, <%= user.name %></h3>
        <p>
            <strong>Contact:</strong> 
            <%= user.contact ? user.contact : 'Not provided' %>
            <button onclick="toggleContactForm(this)" class="btn">Edit</button>
        </p>
        <div id="contactForm" class="contact-card" style="display: none;">
            <p class="contact-title">Update your contact number</p>
                    <form id="contactFormSubmit" action="/update-contact" method="POST">
                        <input type="text" name="contact" placeholder="Enter new contact" maxlength="20" pattern="[0-9]+" required>
                        <input type="hidden" name="redirectTo" value="/technician" />
                        <button type="button" class="btn" onclick="confirmSaveContact()">Save</button>
                    </form>
                </div>
        
        <h3>🚨 P1 - Critical Tickets</h3>

    <table class="table">
    <tr>
        <th>ID</th>
        <th>Title</th>
        <th>Priority</th>
        <th>Status</th>
        <th>Date</th>
        <th>Actions</th>
    </tr>

    <% if (tickets.length === 0) { %>
        <tr>
            <td colspan="5">No critical tickets</td>
        </tr>
    <% } else { %>
        <% tickets.forEach(ticket => { %>
            <tr class="p1-row">
                <tr>
                    <td><%= ticket.ticket_id %></td>
                    <td><%= ticket.title %></td>
                    <td><%= ticket.priority %></td>
                    <td><%= ticket.status %></td>
                    <td><%= new Date(ticket.created_at).toLocaleString('en-PH', {
                        month: 'short',
                        day: 'numeric',
                        hour: '2-digit',
                        minute: '2-digit'
                    }) %></td>
                    <td>
                        <a href="/tickets/view/<%= ticket.ticket_id %>" class="btn">
                            View
                        </a>
                    </td>
                </tr>
            </tr>
        <% }) %>
    <% } %>
</table>
    <a href="/tickets/all" class="btn">View All Tickets</a>
    <a href="/tickets/my" class="btn">My Tickets</a>
    </div>    



</div>

</body>
</html>

<script>
    function toggleContactForm(btn) {
        const form = document.getElementById("contactForm");
        const isHidden = form.style.display === "none" || form.style.display === "";
        if (isHidden) {
            form.style.display = "block";
            btn.innerText = "Hide";
        } else {
            form.style.display = "none";
            btn.innerText = "Edit";
        }
    }
    function confirmLogout() {
        showConfirm("Are you sure you want to logout?", function () {
            window.location.href = "/logout";
        });
    }
    function confirmSaveContact() {
        showConfirm("Save changes to contact number?", function () {
        document.getElementById("contactFormSubmit").submit();
    });
    }
</script>