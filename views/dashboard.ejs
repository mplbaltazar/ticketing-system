<!DOCTYPE html>
<html>
<head>
    <title>Customer Dashboard</title>
<link rel="stylesheet" href="/styles/style.css">
</head>
<body>
    <%- include('header') %>
<div class="container">
    <div class="header">
        <div class="brand-section">
            <h2>
                <span class="brand-highlight">M&B</span> IT Solutions
            </h2>
    
            <p class="company-tagline">
                Client Dashboard
            </p>
        </div>
        <div class="header-actions">
            <a href="/tickets/create?backUrl=<%= backUrl %>"
               class="btn create-btn">
                + Create Ticket
            </a>
            <a href="#"
               onclick="confirmLogout()"
               class="btn logout-btn">
                Logout
            </a>
        </div>
    </div>

    <div class="content">
        <div class="dashboard-card">
            <h3>Welcome, <%= user.name %></h3>
            <div class="profile-info">
                <div class="profile-contact">
                    <span class="profile-label">
                        Contact Number
                    </span>
                    <span class="profile-value">
                        <%= user.contact ? user.contact : 'Not provided' %>
                    </span>
                </div>
                <button onclick="toggleContactForm(this)"
                        class="btn small-btn">
                    Edit
                </button>
            </div>
            <div id="contactForm" class="contact-card" style="display: none;">
                <p class="contact-title">
                    Update your contact number
                </p>
                <form id="contactFormSubmit" action="/update-contact" method="POST">
                    <input type="text" name="contact" placeholder="Enter new contact" maxlength="20" pattern="[0-9]+" required>
                    <button type="button" class="btn" onclick="confirmSaveContact()">
                        Save
                    </button>
                </form>
        
            </div>
        </div>

            <div class="ticket-section">

                <div class="ticket-section-header">
            
                    <div class="ticket-title-group">
                        <h3>📋 My Tickets</h3>
            
                        <span class="ticket-count">
                            <%= tickets.length %> Total Tickets
                        </span>
                    </div>
            
                </div>
            
                <table class="table">
            
                    <tr>
                        <th>ID</th>
                        <th>Title</th>
                        <th>Priority</th>
                        <th>Status</th>
                        <th>Date</th>
                        <th>Actions</th>
                    </tr>
            
                    <% if (tickets.length === 0) { %>
            
                        <tr>
                            <td colspan="6" class="empty-state">
                                📭 No tickets found
                            </td>
                        </tr>
            
                    <% } else { %>
            
                        <% tickets.forEach(ticket => { %>
            
                            <tr>
            
                                <td><%= ticket.ticket_id %></td>
            
                                <td><%= ticket.title %></td>
            
                                <td>
                                    <span class="priority <%= ticket.priority.trim().toLowerCase() %>">
                                        <%= ticket.priority %>
                                    </span>
                                </td>
            
                                <td>
                                    <span class="status-badge status-<%= ticket.status.trim().toLowerCase() %>">
                                        <%= ticket.status %>
                                    </span>
                                </td>
            
                                <td>
                                    <%= new Date(ticket.created_at).toLocaleString('en-PH', {
                                        month: 'short',
                                        day: 'numeric',
                                        hour: '2-digit',
                                        minute: '2-digit'
                                    }) %>
                                </td>
            
                                <td>
                                    <a href="/tickets/view/<%= ticket.ticket_id %>" class="btn">
                                        View
                                    </a>
                                </td>
            
                            </tr>
            
                        <% }) %>
            
                    <% } %>
            
                </table>
            
            </div>
    
</div>

</div>

</body>
</html>

<script>
   function toggleContactForm(btn) {
        const form = document.getElementById("contactForm");
        const isHidden = form.style.display === "none" || form.style.display === "";
        if (isHidden) {
            form.style.display = "block";
            btn.innerText = "Hide";
        } else {
            form.style.display = "none";
            btn.innerText = "Edit";
        }
    }
    function confirmLogout() {
        showConfirm("Are you sure you want to logout?", function () {
        window.location.href = "/logout";
        });
    }
    function confirmSaveContact() {
        showConfirm("Save changes to contact number?", function () {
        document.getElementById("contactFormSubmit").submit();
    });
    }
</script>