<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ticketing System</title>
    <link rel="stylesheet" href="/styles/style.css">
</head>
<body>
    <div class="container">
        <div class="header">
            <h2><span class="brand-highlight">M&B</span> IT Solutions</h2>
            <p class="company-tagline">Technical Support & Repair Services</p>
        </div>
        <div class="content">
            <h1>IT SUPPORT & TICKETING SYSTEM</h1>
            <p>Manage incidents, track repairs, and support users efficiently.</p>
            <div class="login-box">
                <h3>Login</h3>
                <form action="/login" method="POST">
                    <input type="email" name="email" placeholder="Email" required>
                    <input type="password" name="password" placeholder="Password" required>
                    <button type="submit" class="btn">Login</button>
                </form>
                <p>Don't have an account?</p>
                <a href="/register" class="btn">Register</a>
                <a href="/forgot">Forgot Password?</a>
            </div>
        </div>

    </div>