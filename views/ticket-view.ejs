<!DOCTYPE html>
<html>
<head>
    <title>Ticket View</title>
    <link rel="stylesheet" href="/styles/style.css">
</head>
<body>
    <div class="container">
        <div class="header">
            <h2>User Management</h2>
            <a href="<%= backUrl %>" class="btn">Back</a>
            <a href="/logout" class="btn logout">Logout</a>
        </div>
    <div class="ticket-header">
        <h2><%= ticket.title %></h2>
        <div class="ticket-meta">
            <span class="status"><%= ticket.status %></span>
            <span class="priority"><%= ticket.priority %></span>
        </div>
        <div class="ticket-info">
            <% if (role === 'technician') { %>
                <p>
                    <strong>Customer:</strong> 
                    <%= ticket.customer_name %>
                </p>
            
                <p>
                    <strong>Contact:</strong> 
                    <%= ticket.customer_contact || "N/A" %>
                </p>
            <% } %>
            
            <% if (role === 'customer') { %>
                <p>
                    <strong>Assigned Technician:</strong> 
                    <%= ticket.technician_name || "Unassigned" %>
                </p>
            
                <p>
                    <strong>Tech Contact:</strong> 
                    <%= ticket.technician_contact || "N/A" %>
                </p>
            <% } %>
        </div>
        <p><strong>Assigned:</strong> 
            <%= ticket.technician_name || "Waiting for assignment" %>
        </p>
        <% if ((role === 'technician' || role === 'admin') && ticket.status !== 'closed') { %>
            <div class="assign-section">
                <h4>Assign Ticket</h4>
                <form method="POST" action="/tickets/assign">
                    <input type="hidden" name="ticket_id" value="<%= ticket.ticket_id %>">
                    <select name="assigned_to" required>
                        <option value="">Select technician</option>
                        <% technicians.forEach(tech => { %>
                            <option value="<%= tech.user_id %>" 
                                <%= ticket.assigned_to == tech.user_id ? 'selected' : '' %>>
                                
                                <% if (tech.user_id == userId) { %>
                                    Assign to Me
                                <% } else { %>
                                    <%= tech.full_name %>
                                <% } %>
                            </option>
                        <% }) %>
                    </select>
                    <button type="submit">Assign</button>
                </form>
            </div>
        <% } %>
        <p class="description"><%= ticket.description %></p>
    </div>
<div class="comments-section">
    <h4>Comments</h4>

    <% if (comments.length === 0) { %>
        <p>No comments yet</p>
    <% } %>

    <% comments.forEach(comment => { %>
        <div class="comment <%= comment.role %>">
            <div class="comment-header">
                <strong>
                    <%= comment.full_name %>
                    <% if (comment.role === 'admin') { %>
                        <span class="role-tag admin-tag">(Admin)</span>
                    <% } %>
                </strong>
            </div>
    
            <div class="comment-body">
                <%= comment.comment %>
            </div>
    
            <div class="comment-time">
                <%= new Date(comment.created_at).toLocaleString() %>
            </div>
        </div>
    <% }) %>
</div>
<% if (ticket.status !== 'closed' && (userId === ticket.created_by || userId === ticket.assigned_to || role === 'admin')) { %>
    <form method="POST" action="/comments/add" class="comment-form">
        <textarea name="comment" placeholder="Write a reply..." required></textarea>

        <input type="hidden" name="ticket_id" value="<%= ticket.ticket_id %>">

        <button type="submit">Send</button>
    </form>
<% } if (ticket.status === 'closed' && (userId === ticket.created_by || role === 'admin')) { %>
    <p class="text-muted">This ticket is closed. Comments are disabled.</p>
    <form method="POST" action="/tickets/reopen" onsubmit="return getReopenReason()">
        <input type="hidden" name="ticket_id" value="<%= ticket.ticket_id %>">
        <input type="hidden" name="reopen_reason" id="reopen_reason">
        
        <button class="reopen-btn">Reopen Ticket</button>
    </form>
<% } %>
<% if (ticket.status !== 'closed' && (userId === ticket.created_by || userId === ticket.assigned_to || role === 'admin')) { %>
    <form method="POST" action="/tickets/close">
        <input type="hidden" name="ticket_id" value="<%= ticket.ticket_id %>">
        <button class="close-btn" onclick="return confirm('Are you sure you want to close this ticket?')">
            Close Ticket
        </button>
    </form>
<% } %>
    </div>
</body>
</html>

<script>
    function getReopenReason() {
        const reason = prompt("Why are you reopening this ticket?");
        
        if (!reason || reason.trim() === "") {
            alert("Reopen reason is required.");
            return false;
        }
    
        document.getElementById("reopen_reason").value = reason;
        return true;
    }
    </script>